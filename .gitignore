# macOS
.DS_Store

# Gradle / Kotlin Multiplatform
.gradle/
build/
**/build/
local.properties
captures/
.kotlin/
*.kotlin_native_metadata

# Xcode — projects are generated by xcodegen, never commit them
**/*.xcodeproj/
**/*.xcworkspace/xcuserdata/
xcuserdata/
*.xcuserstate
DerivedData/

# Workspace settings stay (the workspace file itself is hand-written)
!Smoothie.xcworkspace/contents.xcworkspacedata

# Swift Package Manager (used transitively by Xcode projects)
.swiftpm/
Package.resolved

# Env / secrets
.env
.env.local
.env.*.local

# Logs
*.log

# Editor
.vscode/
.idea/
*.swp
*.iml
